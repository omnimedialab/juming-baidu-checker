{
  "manifest_version": 3,
  "name": "聚名/Gname 域名 → 百度收录跳转",
  "short_name": "JBD 百度跳转",
  "version": "0.4.0",
  "description": "在聚名网 / Gname 域名列表页,每个域名后面注入一个跳百度 site: 收录查询的小标签,时间段可在弹窗里配置。",
  "default_locale": "zh_CN",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "百度跳转 — 选择时间段",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.juming.com/*",
    "*://*.gname.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.juming.com/*",
        "*://*.gname.com/*"
      ],
      "js": [
        "content/domain-extractor.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
